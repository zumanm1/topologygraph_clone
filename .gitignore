# Node
tests/node_modules/
tests/screenshots/

# macOS
.DS_Store
**/.DS_Store

# Python
__pycache__/
*.pyc
*.pyo

# Temp / scratch
OUTPUT/.tmp_work_*/
IN-OUT-FOLDER/.tmp*/
**/.tmp/

# Credentials / env
.env
*.env
.api-token

# Nested git repos (tracked separately, not as submodules)
topolograph-docker/.env
topolograph-docker/
topolograph/

# Large binary archives
ARCHIVE-MISC/

# Runtime pipeline output (gitignore generated data; keep .gitkeep markers)
IN-OUT-FOLDER/*/
OUTPUT/AS-IS/*/
OUTPUT/GATEWAY/*/
OUTPUT/ENRICHED/*/
OUTPUT/COLLAPSING/*/
OUTPUT/CURRENT/
OUTPUT/DB2/
OUTPUT/ARCHIVE_OLD/

# Bash quirks from terminal tests
EXIT=
echo
tests/EXIT=
tests/echo
INPUT-FOLDER/Load-hosts.csv
