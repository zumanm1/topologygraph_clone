# Node
tests/node_modules/
tests/screenshots/

# macOS
.DS_Store
**/.DS_Store

# Python
__pycache__/
*.pyc
*.pyo

# Temp / scratch
OUTPUT/.tmp_work_*/
IN-OUT-FOLDER/.tmp*/
**/.tmp/

# Credentials / env
# .env is now tracked with safe defaults - users can modify if needed
*.env.local
.api-token

# Nested git repos (tracked separately, not as submodules)
topolograph-docker/.env
topolograph-docker/
topolograph/

# Large binary archives
ARCHIVE-MISC/

# Runtime pipeline output (gitignore generated data; keep .gitkeep markers)
IN-OUT-FOLDER/*/
OUTPUT/AS-IS/*/
OUTPUT/GATEWAY/*/
OUTPUT/ENRICHED/*/
OUTPUT/COLLAPSING/*/
OUTPUT/CURRENT/
OUTPUT/DB2/
OUTPUT/ARCHIVE_OLD/

# Bash quirks from terminal tests
EXIT=
echo
tests/EXIT=
tests/echo
INPUT-FOLDER/Load-hosts.csv

# Generated output folders (regenerated on demand)
IN-OUT-FOLDER/
OUTPUT/

# Backup hostname files
INPUT-FOLDER copy/

# Allow test data files (sample files for users)
!INPUT-FOLDER/Load-hosts-metro-level.csv
!INPUT-FOLDER/ospf-database-54-unk-test.txt

# Ignore all other INPUT-FOLDER files (user uploads)
INPUT-FOLDER/*.csv
INPUT-FOLDER/*.txt

# Validation reports (generated)
*-STEP-BY-STEP/validation-report.txt
*-STEP-BY-STEP/pipeline-report.txt
