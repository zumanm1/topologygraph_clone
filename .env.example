# =============================================================================
# .env.example — OSPF Country Topology Docker Stack
# =============================================================================
# Copy this to .env and edit before running `docker compose up -d`
#
#   cp .env.example .env
#
# REQUIRED changes:  MONGODB_PASSWORD, TOPOLOGRAPH_WEB_API_PASSWORD
# OPTIONAL changes:  TOPOLOGRAPH_PORT if 8081 is taken on your server
# =============================================================================

# ── Topolograph Web Server ────────────────────────────────────────────────────
TOPOLOGRAPH_PORT=8081

# ── Auxiliary host ports (localhost only) ─────────────────────────────────────
# These defaults avoid conflicts with the original Topolograph Docker stack.
MCP_PORT=8001
MONGODB_PORT=27018

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_DATABASE=admin
MONGODB_USERNAME=admin
MONGODB_PASSWORD=myadminpassword
MONGODB_HOSTNAME=mongodb

# ── Layout persistence database (blank dedicated DB) ──────────────────────────
LAYOUT_DB_NAME=topolograph_layouts
LAYOUT_DB_USER=layout_user
LAYOUT_DB_PASSWORD=layout_password

# ── Topolograph API ───────────────────────────────────────────────────────────
TOPOLOGRAPH_WEB_API_USERNAME_EMAIL=ospf@topolograph.com
TOPOLOGRAPH_WEB_API_PASSWORD=ospf
TOPOLOGRAPH_BOOTSTRAP_SECRET=change-me-bootstrap-secret
TOKEN_HASH_SECRET=change-me-token-hash-secret
# Keep this as narrow as possible; widen only if you need API access from LAN/VPN clients.
TOPOLOGRAPH_WEB_API_AUTHORISED_NETWORKS=127.0.0.1/32,172.16.0.0/12,192.168.65.0/24

# ── Security hardening ─────────────────────────────────────────────────────────
ENABLE_SECURITY_HEADERS=true
SESSION_COOKIE_SAMESITE=Lax
SESSION_COOKIE_SECURE=false

# ── NAPALM (optional — not needed for OSPF topology) ─────────────────────────
NAPALM_USERNAME=
NAPALM_PASSWORD=
NAPALM_PORT=22

# ── DNS (used by Flask container) ─────────────────────────────────────────────
DNS=8.8.8.8

# ── NetBox (optional — not needed for OSPF topology) ─────────────────────────
NETBOX_URL=http://localhost:8000
NETBOX_RO_TOKEN=
